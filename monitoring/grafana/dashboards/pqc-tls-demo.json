      "pluginVersion": "12.4.3",
      "targets": [
        {
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum by (http_user_agent, ssl_curve, pqc) (count_over_time({namespace=\"pqc-demo\", container=\"nginx\"} | json | ssl_curve != \"\" | ssl_curve != \"unknown\" | http_user_agent != \"\" | label_format pqc=`{{ regexReplaceAll \"(?i).*mlkem.*\" .ssl_curve \"PQC\" }}` | label_format pqc=`{{ if eq .pqc \"PQC\" }}PQC{{ else }}Classical{{ end }}` [$__range]))",
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "${loki_ds}"
          }
        }
