    {
      "datasource": {
        "type": "loki",
        "uid": "${loki_ds}"
      },
      "description": "PQC vs classical, grouped by the real HTTP User-Agent (NGINX's $http_user_agent) rather than the client's self-reported name. PQC = negotiated group name (NGINX's $ssl_curve) matches /mlkem/i (currently only X25519MLKEM768); everything else observed is classical ECDHE. Sourced from container=\"nginx\", filtered to a non-empty user-agent. Shows every client that sends a real HTTP request: go-dual-share and curl-pq/curl-classic (their tools' default user agents), plus the three openssl s_client-based clients (openssl-35-dual, openssl-classic-only, hrr-trigger), each of which sends a GET /handshake-info request with its own client name set as the User-Agent header. Only legacy-tls12 never appears here: its TLS handshake fails outright (capped at TLS 1.2 against a TLS-1.3-only server), so NGINX never logs a line for it at all. A table rather than a bar chart: Grafana's barchart panel collapses multi-series Loki instant-query results by their shared timestamp before rendering, discarding per-series names. The PQC/Classical split showed up as bar height but the legend/coloring never worked. A table has no such ambiguity.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "footer": {
              "reducers": []
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "pqc"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Category"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "Classical": {
                        "color": "blue",
                        "index": 1
                      },
                      "PQC": {
                        "color": "green",
                        "index": 0
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Connections"
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          }
        ]
      },
